		"prefix": "mutable",
		"body": [
			"\"\"\"${1:Description of this mutable operation}.\"\"\"",
			"mutable ${2:void} ${3:functionName}(${4:args});$0"
		],
		"description": "A mutable function in a attachment function pool (modifies state)"
	},
	"A query function": {
		"prefix": "query",
		"body": [
			"\"\"\"${1:Description of this query}.\"\"\"",
			"${2:ReturnType} ${3:functionName}(${4:args});$0"
		],
		"description": "A query function in an attachment function pool (read-only)"
	},
	"The id attribute": {
		"prefix": "aid",
		"body": [
			"{${1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}}$0"
		],
		"description": "Attribute ID with UUID placeholder (replace x's with actual UUID)"
