		"prefix": "enum-field",
		"body": [
			"${1:EnumType} ${2:fieldName} = .${3:enumValue};$0"
		],
		"description": "A struct field with enum type and default value"
	},
	"A structure": {
		"prefix": "struct",
		"body": [
