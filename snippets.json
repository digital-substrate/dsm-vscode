      "membership ${1:Club} ${2:Concept};$0"
    ],
    "description": "a structure"
    },
	"An enumeration": {
		"prefix": "enum",
		"body": [
			"enum ${1:name} {",
			"   ${2:value1},",
			"   ${3:value2}",
			"   $0",
			"};"
		],
		"description": "An enumeration declaration"
	},
