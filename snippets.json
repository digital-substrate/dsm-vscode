		"prefix": "attachment",
		"body": [
            "attachment<${1:ConceptName}, ${2:StructName}> ${3:attachmentName};$0"
		],
		"description": "An attachment linking a concept to a data structure"
	},
	"An attachment block": {
		"prefix": "attachment-block",
		"body": [
			"// Attachments",
			"namespace ${1:MyNamespace} {${2:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}} {",
			"",
			"\"\"\"${3:Description of attachment}.\"\"\"",
			"attachment<${4:ConceptName}, ${5:StructName}> ${6:attachmentName};",
			"",
			"$0",
			"};"
		],
		"description": "A complete attachment namespace block with docstring"
	},
	"A function pool": {
		"prefix": "function_pool",
		"body": [
			"function_pool ${1:name} {${2:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}} {",
			"   $0",
			"};"
		],
		"description": "A function pool with UUID (replace x's with actual UUID)"
	},
	"An attachment function pool": {
		"prefix": "attachment_function_pool",
		"body": [
			"\"\"\"${1:Description of this attachment function pool}.\"\"\"",
			"attachment_function_pool ${2:ModelName} {${3:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}} {",
			"",
			"   \"\"\"${4:Description of function}.\"\"\"",
			"   mutable ${5:void} ${6:functionName}(${7:args});",
			"   $0",
			"};"
		],
		"description": "A attachment function pool with mutable function template"
	},
