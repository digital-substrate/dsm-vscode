		],
		"description": "A concept declaration"
	},
	"A concept with inheritance": {
		"prefix": "isa",
		"body": [
			"concept ${1:DerivedConcept} is a ${2:BaseConcept};$0"
		],
		"description": "A concept with single inheritance (is a)"
	},
