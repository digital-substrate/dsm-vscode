		"prefix": "opt-key",
		"body": [
			"optional<key<${1:ConceptName}>> ${2:fieldName}Key;$0"
		],
		"description": "An optional key field (nullable reference to a concept)"
	},
	"A namespace": {
		"prefix": "namespace",
		"body": [
			"namespace ${1:name} {${2:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}} {",
			"   $0",
			"};"
		],
		"description": "A namespace with UUID (replace x's with actual UUID)"
	},
	"A concept": {
		"prefix": "concept",
		"body": [
